---
interface CurrentProject {
  title: string;
  description: string;
  tags: string[];
  link?: string;
}

interface PastProject {
  tag: string;
  metric: string;
  title: string;
  description: string;
  stack: string[];
}

const currentProjects: CurrentProject[] = [
  {
    title: 'Wildtide',
    description:
      "An indirect auto-city builder where you govern through policies instead of placing buildings manually. Imagine WorldBox meets Frostpunk, wrapped in a peaceful Terra Nil aesthetic. It packs hex terrain, faction AI, wave survival, and a working economy. It's a chaotic early prototype right now, but under very active development.",
    tags: ['Godot 4.6', 'GDScript', 'Game Dev'],
  },
  {
    title: 'Bookie AI Video Pipeline',
    description:
      "An automated pipeline that magically turns books into narrated video content for Bookie (a Vietnamese reading community I co-founded). It autonomously handles research, storyboarding, scripting, AI visuals, TTS, and Remotion video assembly. You type one command, grab a coffee, and come back to a fully rendered production.",
    tags: ['Remotion', 'Claude API', 'viXTTS', 'Gemini API'],
    link: 'https://github.com/haingt-dev/Bookie',
  },
  {
    title: 'Agent Hub',
    description:
      "My personal infrastructure to keep Claude Code sane. It manages global skills, plugins, hooks, and bootstraps projects across a messy multi-repo workspace. Effectively, it turns Claude from isolated per-project islands into a unified, connected assistant that actually remembers my preferences.",
    tags: ['Claude Code', 'Bash', 'MCP', 'Node.js'],
    link: 'https://github.com/haingt-dev/agent',
  },
];

const pastProjects: PastProject[] = [
  {
    tag: 'Performance Engineering',
    metric: '36 hrs → 2 hrs',
    title: 'Matching System Optimization',
    description:
      "A classic nightmare: a nightly matching job was taking 36 hours to chew through data, completely breaking our SLAs. Instead of throwing expensive servers at the problem, I dug into the query planner, rewrote the core algorithm from scratch, and added targeted indexes. The job now casually finishes in under 2 hours using the exact same infrastructure.",
    stack: ['PostgreSQL', 'Node.js', 'Query Optimization'],
  },
  {
    tag: 'AI Integration',
    metric: 'Manual → automated',
    title: 'AI-Powered Content Pipeline',
    description:
      "The content team was stuck manually drafting and scheduling posts across three platforms, eating up 5 hours a week. I built an n8n pipeline that slurps up raw notes, formats drafts via the Claude API, and queues them for human review before auto-publishing. The team now spends 30 minutes clicking 'Approve' and 4.5 hours doing actual creative work.",
    stack: ['n8n', 'Claude API', 'Node.js', 'Webhook'],
  },
];
---

<section id="projects">
  <div class="container">
    <p class="section-label reveal">What I'm building</p>
    <h2 class="reveal">Projects</h2>
    <div class="grid">
      {
        currentProjects.map((p, index) => (
          <div class="card reveal" style={`transition-delay: ${index * 100}ms`}>
            <div class="mac-dots">
              <span class="mac-dot"></span>
              <span class="mac-dot"></span>
              <span class="mac-dot"></span>
            </div>
            <h3>
              {p.link ? (
                <a href={p.link} target="_blank" rel="noopener noreferrer" class="project-link">
                  {p.title} <span class="arrow">↗</span>
                </a>
              ) : (
                p.title
              )}
            </h3>
            <p class="desc">{p.description}</p>
            <div class="stack">
              {p.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <p class="section-label subsection reveal">Track record</p>
    <h3 class="subsection-heading reveal">Past work</h3>
    <div class="past-grid">
      {
        pastProjects.map((p, index) => (
          <div class="card reveal" style={`transition-delay: ${index * 100}ms`}>
            <div class="mac-dots">
              <span class="mac-dot"></span>
              <span class="mac-dot"></span>
              <span class="mac-dot"></span>
            </div>
            <span class="tag">{p.tag}</span>
            <p class="metric">{p.metric}</p>
            <h3>{p.title}</h3>
            <p class="desc">{p.description}</p>
            <div class="stack">
              {p.stack.map((s) => (
                <span class="tag">{s}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 { margin-bottom: 2.5rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card h3 { color: var(--color-text); }

  .project-link {
    color: var(--color-text);
    transition: color 0.15s;
  }

  .project-link:hover {
    color: var(--color-accent);
  }

  .project-link:hover .arrow {
    opacity: 1;
    transform: translate(3px, -3px);
  }

  .arrow {
    display: inline-block;
    font-size: 0.8em;
    opacity: 0.5;
    transition: opacity 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .metric {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    max-width: none;
    background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 50%, #93c5fd 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 8px rgba(59, 130, 246, 0.2));
  }

  .desc {
    color: var(--color-muted);
    font-size: 0.93rem;
    line-height: 1.7;
    max-width: none;
    flex: 1;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .past-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .past-grid .desc {
      column-count: 2;
      column-gap: 2rem;
    }
  }

  .subsection {
    margin-top: 4rem;
  }

  .subsection-heading {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    margin-bottom: 2rem;
    color: var(--color-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow {
      transition: none;
    }

    .project-link {
      transition: none;
    }
  }
</style>
