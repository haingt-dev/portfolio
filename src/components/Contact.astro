---
---

<section id="contact" class="contact-section">
  <div class="container">
    <p class="section-label reveal">Get in touch</p>
    <h2 class="reveal">Let's build something</h2>
    <p class="body-text reveal">
      I'm currently available for select freelance gigs on Upwork or direct contracts.<br />
      If you want to collaborate on game dev tools, AI pipelines, or anything that automates away boring work, I'm all ears.<br />
      I usually reply within 24 hours (unless I'm catching up on sleep before the baby arrives).
    </p>
    <div class="cta-row reveal">
      <a
        href="https://www.upwork.com/freelancers/haingtdev"
        class="btn btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Upwork Profile →
      </a>
    </div>
    <div class="links reveal">
      <div class="email-wrapper" style="position: relative; display: inline-flex; align-items: center;">
        <a href="mailto:hai@haingt.dev" class="link" id="email-link" title="Send email (or copy to clipboard)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="M22 7l-10 7L2 7" />
          </svg>
          hai@haingt.dev
        </a>
        <span id="email-tooltip" class="tooltip">Copied to clipboard!</span>
      </div>
      <a
        href="https://github.com/haingt-dev"
        class="link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/haingt-dev"
        class="link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        LinkedIn
      </a>
    </div>
  </div>
  <script>
    const emailLink = document.getElementById('email-link');
    const tooltip = document.getElementById('email-tooltip');
    
    if (emailLink && tooltip) {
      emailLink.addEventListener('click', () => {
        // Automatically copy to clipboard as a fallback for OS without mail clients
        navigator.clipboard.writeText('hai@haingt.dev').then(() => {
          tooltip.classList.add('show');
          setTimeout(() => tooltip.classList.remove('show'), 2000);
        }).catch(() => {});
      });
    }
  </script>
</section>

<style>
  .contact-section {
    padding-block: clamp(6rem, 12vw, 10rem);
    background: radial-gradient(
      ellipse at top,
      rgba(59, 130, 246, 0.03) 0%,
      var(--color-bg) 70%
    );
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 { margin-bottom: 1.25rem; }

  .body-text {
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .cta-row { margin-bottom: 2rem; }

  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    padding: 0.5rem 0;
    transition: color 0.15s;
  }

  .link:hover { color: var(--color-accent); }

  .link svg {
    display: inline-block;
    flex-shrink: 0;
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  .link:hover svg {
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .link {
      transition: none;
    }
  }

  .tooltip {
    position: absolute;
    top: -30px;
    left: 50%;
    transform: translateX(-50%) translateY(5px);
    background: var(--color-surface-hover);
    color: var(--color-accent);
    padding: 6px 10px;
    border-radius: var(--radius, 6px);
    font-size: 0.75rem;
    font-family: var(--font-mono);
    opacity: 0;
    pointer-events: none;
    border: 1px solid var(--color-border);
    white-space: nowrap;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: var(--shadow-card);
  }
  
  .tooltip.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
