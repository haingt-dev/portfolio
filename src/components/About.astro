---
const skills = {
  Backend: ["Node.js", "AWS", "MongoDB", "Redis", "PostgreSQL", "SQL"],
  AI: ["Claude API", "OpenAI API", "MCP", "n8n"],
  "Game Dev": ["Godot 4.6", "GDScript"],
  Video: ["Remotion", "viXTTS", "Gemini API"],
  Tools: ["Git", "Linux", "Docker", "Cloudflare"],
};
---

<section id="about">
  <div class="container">
    <p class="section-label reveal">Background</p>
    <h2 class="reveal">About</h2>
    <div class="layout reveal">
      <div class="bio">
        <p>
          I'm a backend developer based in Ho Chi Minh City, currently building my way out of 
          traditional employment. After 7 years of wrestling with Node.js and scaling AWS infrastructure, 
          I decided it was time to build things for myself. Now, I'm piecing together my own indie 
          game dev ecosystem—where every tool, game, and content pipeline I write inevitably ends up 
          serving the others.
        </p>
        <p>
          Nine years ago, I co-founded <a
            href="https://www.bookiecommunity.com"
            target="_blank"
            rel="noopener noreferrer"
            ><strong>Bookie</strong>
          </a>, a Vietnamese reading community. These days, I'm wiring up an AI video pipeline for it 
          that turns books into fully narrated videos with a single command (because manual editing
          is for the birds). I'm also developing <strong>Wildtide</strong>, an indirect city builder in Godot, and hacking on <a
            href="https://github.com/haingt-dev/agent"
            target="_blank"
            rel="noopener noreferrer"
            ><strong>Agent Hub</strong>
          </a> to make Claude Code actually useful across multiple projects without losing its mind.
        </p>
        <p>
          I'm a systems thinker by day, an unapologetic city-builder addict by night, and I'm expecting 
          my first kid in April 2026. Send sleep tips.
        </p>
      </div>
      <div class="skills reveal">
        {
          Object.entries(skills).map(([category, items]) => (
            <div class="skill-group">
              <p class="skill-category">{category}</p>
              <div class="skill-items">
                {items.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  h2 {
    margin-bottom: 2.5rem;
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .layout {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .bio p {
    color: var(--color-muted);
    line-height: 1.8;
  }

  .bio strong {
    color: var(--color-text);
    font-weight: 600;
    box-shadow: inset 0 -4px 0 var(--color-accent-glow);
    transition: background-color 0.2s ease-out, box-shadow 0.2s ease-out;
    padding-inline: 0.1em;
    border-radius: 2px;
  }

  .bio strong:hover {
    background-color: var(--color-accent-glow);
    box-shadow: inset 0 -1.5em 0 var(--color-accent-glow);
  }

  .tag {
    cursor: default;
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-category {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    max-width: none;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
